<h2>Connexion</h2>

<form (ngSubmit)="onSubmit()" #loginForm="ngForm">
  <input type="email" name="email" [(ngModel)]="credentials.email" placeholder="Email" required /><br />
  <input type="password" name="password" [(ngModel)]="credentials.password" placeholder="Mot de passe" required /><br />
  <button type="submit" [disabled]="!loginForm.valid">Se connecter</button>
</form>
