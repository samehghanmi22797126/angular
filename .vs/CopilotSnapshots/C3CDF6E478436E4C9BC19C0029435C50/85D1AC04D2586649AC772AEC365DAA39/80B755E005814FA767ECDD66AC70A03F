using Microsoft.EntityFrameworkCore;
using sale_sport.Models;

namespace sale_sport.Data
{
    public class ApplicationDbContext : DbContext
    {
        public ApplicationDbContext(DbContextOptions<ApplicationDbContext> options) : base(options)
        {
        }

        public DbSet<Member> Members => Set<Member>();
        // Subscription model is used in this project
        public DbSet<Subscription> Subscriptions => Set<Subscription>();
        public DbSet<sale_sport.Models.Admin> Admins => Set<sale_sport.Models.Admin>();
        public DbSet<sale_sport.Models.Coach> Coaches => Set<sale_sport.Models.Coach>();
    }
}
